{
  "name": "classificator",
  "description": "Naive Bayes classifier with verbose informations for node.js",
  "version": "1.0.0",
  "author": "Wozacosta",
  "keywords": [
    "naive",
    "bayes",
    "categorize",
    "classify",
    "classifier",
    "classification",
    "classificator",
    "nbayes",
    "likelihood",
    "machine learning",
    "bayesian",
    "typescript"
  ],
  "dependencies": {
    "decimal.js": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Wozacosta/classificator.git"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  }
}
